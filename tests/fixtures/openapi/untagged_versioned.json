{
  "openapi": "3.1.0",
  "info": { "title": "Versioned API", "version": "1.0.0" },
  "paths": {
    "/api/v1/samples": {
      "get": {
        "operationId": "listSamples",
        "summary": "List samples",
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/v2/runs/{id}": {
      "get": {
        "operationId": "getRun",
